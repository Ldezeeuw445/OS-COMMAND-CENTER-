# OS Command Center local API port
OSCC_API_PORT=8787
OSCC_MONITOR_INTERVAL_MS=60000
OSCC_ALERT_HISTORY_LIMIT=200
OSCC_ALERT_STRIPE_OUTFLOW_30D=5000
OSCC_ALERT_METAAPI_MIN_BALANCE=0
OSCC_NOTIFY_COOLDOWN_MS=900000
OSCC_NOTIFY_WARNINGS=0

# Supabase (server-only secrets)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# AXE / AXE Core integration (server-only secrets)
AXE_CORE_LOGS_ENDPOINT=
AXE_CORE_LOGS_TOKEN=
AXE_COMPANION_API_URL=
AXE_COMPANION_API_TOKEN=

# Platform integrations (server-only secrets)
STRIPE_SECRET_KEY=
GITHUB_TOKEN=
VERCEL_TOKEN=
CLOUDFLARE_API_TOKEN=
METAAPI_TOKEN=
METAAPI_ACCOUNT_ID=
METAAPI_REGION=new-york
OPENAI_API_KEY=
RAILWAY_TOKEN=
ALERT_WEBHOOK_URL=
ALERT_SLACK_WEBHOOK_URL=
ALERT_TELEGRAM_BOT_TOKEN=
ALERT_TELEGRAM_CHAT_ID=

# Never expose secrets in frontend env vars.
# Do NOT use VITE_ prefixed variables for secret keys.
